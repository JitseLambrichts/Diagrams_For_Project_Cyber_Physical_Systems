@startuml BehaviouralView
title Sequence - Robot voert pick-taak uit

actor Operator
participant "OperatorWebApp" as UI
participant "REST API" as REST
participant "TaskQueueService" as TQS
participant "WorldModelService" as WMS
participant "RobotController" as RC
participant "RobotCommAdapter" as RCA
participant "ActuatorsAdapter" as AA
participant "SensorsAdapter" as SA

' operator voegt item toe
Operator -> UI : add item to queue
UI -> REST : POST /tasks
REST -> TQS : createTask(item)
TQS --> REST : taskId
REST --> UI : 201 Created

== Robot requests task ==

RC -> SA : read current position
SA --> RC : position

RC -> RCA : request new task
RCA -> REST : GET /robots/{id}/nextTask
REST -> WMS : reserve aisle for task
WMS --> REST : OK (aisle reserved)
REST --> RCA : taskdetails (location, aisle)
RCA --> RC : task details

== Robot drives to location ==

RC -> RC : plan path to goal
loop each control-cyclus
  RC -> SA : read sensors
  SA --> RC : sensorvalues
  RC -> AA : send motor commands
  AA --> RC : ack
  RC -> RCA : send status update (location, state)
end

== Task completed ==

RC -> RCA : report task completed
RCA -> REST : POST /robots/{id}/taskCompleted
REST -> WMS : clear the aisle
WMS --> REST : OK
REST --> RCA : 200 OK
RCA --> RC : clear the aisle

@enduml
